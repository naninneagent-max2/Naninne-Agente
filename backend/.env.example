# =============================================================================
# Naninne — backend .env (Sprint 0)
# =============================================================================
# Copie este arquivo para .env e preencha as chaves reais:
#   cp .env.example .env
#
# Dica: no sandbox de desenvolvimento do Robert há um Postgres local em
# localhost:5432 com usuário `naninne` / senha `naninne_dev` / db `naninne`.
# Em produção, o DSN aponta para o Supabase.
# =============================================================================

# ── Banco de dados (Supabase Postgres) ─────────────────────────────────────
DATABASE_URL=postgresql://naninne:naninne_dev@localhost:5432/naninne
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# ── Supabase (REST) ────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Provedores de LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Modelos (nomes override-áveis) ─────────────────────────────────────────
CLAUDE_SONNET_MODEL=claude-sonnet-4-5
GEMINI_PRO_MODEL=gemini-2.5-pro
QWEN_ROUTER_MODEL=qwen3-8b
HERMES_MODEL=hermes-4.3-36b

# ── Endpoints self-hosted (Qwen3 e Hermes) ─────────────────────────────────
# Preencha quando o stack self-hosted do Robert estiver disponível.
# Servidores compatíveis com a API da OpenAI (ex: vLLM, TGI, Ollama).
QWEN_ROUTER_BASE_URL=
HERMES_BASE_URL=

# ── Observabilidade (LangSmith) ────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=naninne-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=false

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Origens do frontend Next.js (CORS). Adicione a URL do Vercel em produção.
API_CORS_ORIGINS=["http://localhost:3000"]
ENVIRONMENT=dev

# ── Checkpointer ───────────────────────────────────────────────────────────
# `postgres` (default) usa o Supabase; `sqlite` usa arquivo local — útil
# para sandbox e CI sem Postgres remoto. O código cai automaticamente para
# sqlite se o postgres estiver indisponível, mas com WARNING.
CHECKPOINTER_BACKEND=postgres
SQLITE_CHECKPOINTER_PATH=.checkpoints/naninne.db

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
