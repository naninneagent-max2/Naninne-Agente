# =====================================================================
# Naninne — Environment Variables
# =====================================================================
# Copy this file to `.env.local` and fill in the real values.
# NEVER commit `.env.local` to git (it is gitignored).
# =====================================================================

# ---- Supabase (client + server) --------------------------------------
# Found in: Supabase dashboard → Project Settings → API
# Safe to expose to the browser — protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY-HERE"

# ---- Backend API (LangGraph orchestrator) ----------------------------
# Public URL of the FastAPI / LangGraph server.
# Local dev:  http://localhost:8000
# Production: https://api.naninne.app
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ---- Supabase (server-only) -----------------------------------------
# Found in: Supabase dashboard → Project Settings → API → service_role
# ⚠️  NEVER expose this to the browser — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY-HERE"

# ---- OpenAI (server-only) -------------------------------------------
# Used for embeddings (text-embedding-3-small) and any OpenAI fallback.
# ⚠️  Server-only — never prefix with NEXT_PUBLIC_.
OPENAI_API_KEY="sk-YOUR-OPENAI-KEY-HERE"
